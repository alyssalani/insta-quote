# Copy this file to .env and fill in the values from your Firebase project's
# web app config (Firebase console → Project settings → General → Your apps
# → SDK setup and configuration → Config). These are safe to expose in a
# client bundle — real access control lives in firestore.rules, not here.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
